{
  "framework": "nextjs",
  "headers": [
    {
      "source": "/(.*)\\.(js|css|woff2|avif|webp|jpg|png|svg|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/fr",
      "permanent": false
    }
  ]
}
